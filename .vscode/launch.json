    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}",
            "args": "/path/to/keystore.jks keystore-password",
            "env": {
                "DATABASE_PATH": "/path/to/database.db"
            }
        },
        {
            "type": "java",
            "name": "Server",
            "request": "launch",
            "mainClass": "com.o3.server.Server",
            "projectName": "server",
            "args": "/path/to/keystore.jks keystore-password",
            "env": {
                "DATABASE_PATH": "/path/to/database.db"
            }
        }
    ]
}
